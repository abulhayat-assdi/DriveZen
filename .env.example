# Copy this file to .env and fill in real values before deploying.
# `docker compose` reads this file automatically.

# --- PostgreSQL (used by the `db` service and by DATABASE_URL below) ---
POSTGRES_USER=drivezen
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=drivezen

# --- App ---
# Session cookie signing key. Generate one with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-long-random-string

# Public port the app is exposed on (nginx should proxy to this)
APP_PORT=3000

# Optional: pins the Docker Compose project name (used as a prefix for
# volume/network names) regardless of the folder name you clone into.
COMPOSE_PROJECT_NAME=drivezen

# --- One-time seed (docker compose --profile tools run --rm seed) ---
# Change these before seeding a production database — the seed script
# falls back to demo credentials (admin@drivezen.com / admin123) if unset.
ADMIN_EMAIL=admin@drivezen.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# --- Local (non-Docker) development only ---
# DATABASE_URL=postgresql://drivezen:change-me-to-a-strong-password@localhost:5432/drivezen

# --- Deploying as a single Coolify app (no docker-compose.yml) ---
# docker-compose.yml's `migrate`/`app` services build DATABASE_URL for you from
# the POSTGRES_* vars above, but a single-app Coolify deployment only runs the
# Dockerfile directly — nothing sets DATABASE_URL for you. Add these two as
# actual Environment Variables in the Coolify app's dashboard (not this file):
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
#     (HOST is the internal service name/host of whatever Postgres you
#     provisioned — e.g. a Coolify-managed Postgres resource's internal
#     hostname, shown on that resource's page — not "localhost" or "db")
#   AUTH_SECRET=<a long random string, e.g. `openssl rand -base64 32`>
#     (required in production — without it, admin sessions fall back to a
#     secret hardcoded in lib/auth.ts, which anyone reading the repo can see)
