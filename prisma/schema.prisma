// Drive Zen - Prisma schema (PostgreSQL)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Singleton site-wide settings (id is always "singleton")
model SiteSettings {
  id           String  @id @default("singleton")
  brandName    String  @default("Drive Zen")
  tagline      String  @default("Premium Car Accessories")
  logoUrl      String?
  whatsapp     String  @default("01608221914")
  phone        String  @default("01608221914")
  messengerUrl String?
  facebookUrl  String?
  address      String?
  email        String?

  // Hero + marketing copy
  heroKicker   String  @default("")
  heroHeadline String  @default("The upgrade your drive deserves.")
  announcement String?

  // Delivery
  deliveryInside  Int @default(0) // Dhaka
  deliveryOutside Int @default(0)

  // Theming
  primaryColor String @default("#e0b04f")
  currency     String @default("৳")

  footerText String @default("")

  // Steadfast Courier API credentials
  steadfastApiKey    String?
  steadfastSecretKey String?

  // Facebook Pixel + Conversions API
  fbPixelId     String?
  fbAccessToken String?

  updatedAt DateTime @updatedAt
}

// Generic key/value store for every editable text on the landing page
// (button labels, section headings, nav labels, etc.)
model SiteContent {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Product {
  id          String  @id @default(cuid())
  name        String
  tagline     String  @default("")
  badge       String? // e.g. "New", "Best Seller"
  price       Int     @default(0)
  oldPrice    Int?
  priceNote   String? // e.g. "সারা দেশে ফ্রি ডেলিভারি"
  shortDesc   String  @default("")
  description String  @default("")
  heroImage   String?
  isActive    Boolean @default(false)
  sortOrder   Int     @default(0)

  images     ProductImage[]
  features   Feature[]
  highlights Highlight[]
  orders     Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String  @default("")
  sortOrder Int     @default(0)
}

// "What's included" checklist items
model Feature {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  icon      String  @default("check")
  text      String
  sortOrder Int     @default(0)
}

// Big image + text highlight sections
model Highlight {
  id          String  @id @default(cuid())
  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl    String?
  title       String
  description String  @default("")
  sortOrder   Int     @default(0)
}

model Faq {
  id        String @id @default(cuid())
  question  String
  answer    String
  sortOrder Int    @default(0)
}

model Order {
  id             String  @id @default(cuid())
  orderNumber    String  @unique
  productId      String?
  product        Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName    String
  customerName   String
  phone          String
  address        String
  area           String  @default("inside") // inside | outside
  quantity       Int     @default(1)
  unitPrice      Int     @default(0)
  deliveryCharge Int     @default(0)
  couponCode     String?
  discountAmount Int     @default(0)
  total          Int     @default(0)
  note           String?
  status         String  @default("new") // new|on_the_way|confirmed|cancelled

  // Steadfast Courier
  courierConsignmentId String?
  courierTrackingCode  String?
  courierStatus        String?
  courierSentAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String   @default("Admin")
  createdAt    DateTime @default(now())
}

// Discount codes redeemable in the public order flow
model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique // stored uppercase, e.g. "SAVE10"
  type           String    // "percent" | "fixed"
  value          Int       // percent points (1-100) or fixed Taka amount
  minOrderAmount Int       @default(0)
  maxUses        Int?      // null = unlimited
  usedCount      Int       @default(0)
  expiresAt      DateTime?
  isActive       Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Manual phone/IP blocklist enforced at order-creation time
model BlockedEntry {
  id        String   @id @default(cuid())
  type      String   // "phone" | "ip"
  value     String   // normalized 01XXXXXXXXX for phone, raw string for ip
  reason    String?
  createdAt DateTime @default(now())

  @@unique([type, value])
}

// Partial/in-progress checkout captures, for abandoned-cart follow-up.
// sessionId is client-generated (crypto.randomUUID(), kept in sessionStorage)
// and is the join key back to a completed Order.
model DraftOrder {
  sessionId        String    @id
  productId        String?
  productName      String?
  name             String?
  phone            String?
  address          String?
  note             String?
  quantity         Int?
  area             String?
  completedOrderId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([completedOrderId])
  @@index([updatedAt])
}
